{
  "steps": [
    {
      "id": "session.open_test_client",
      "intent": "session.open_test_client",
      "canonical_text": "Дано Я открыл новый сеанс TestClient или подключил уже существующий",
      "ui_scope": "session",
      "parameters": []
    },
    {
      "id": "ui.close_all_windows",
      "intent": "ui.close_all_windows",
      "canonical_text": "И Я закрыл все окна клиентского приложения",
      "ui_scope": "session",
      "parameters": []
    },
    {
      "id": "navigation.open_section",
      "intent": "navigation.open_section",
      "canonical_text": "Когда В панели разделов я выбираю \"%1 ИмяКоманды\"",
      "ui_scope": "navigation",
      "parameters": [
        { "name": "section_name", "type": "string", "required": true, "defaultValue": null }
      ]
    },
    {
      "id": "catalog.open_list_form",
      "intent": "catalog.open_list_form",
