      "intent": "ui.close_current_window",
      "canonical_text": "И Я закрываю текущее окно",
      "ui_scope": "form",
      "parameters": []
    },
    {
      "id": "client.close_named",
      "intent": "client.close_named",
      "canonical_text": "И я закрываю TestClient \"%1 ИмяКлиента\"",
      "ui_scope": "session",
      "parameters": [
        { "name": "client_name", "type": "string", "required": true, "defaultValue": "Этот клиент" }
      ]
    }
  ],
  "recipes": [
